on inventory click:
    add air to {_alloweditems::*}
    add coal to {_alloweditems::*}
    add iron ingot to {_alloweditems::*}
    add copper ingot to {_alloweditems::*}
    add gold ingot to {_alloweditems::*}
    add diamond to {_alloweditems::*}
    add emerald to {_alloweditems::*}
    add lapis lazuli to {_alloweditems::*}
    add redstone to {_alloweditems::*}
    add quartz to {_alloweditems::*}
    add amethyst shard to {_alloweditems::*}
    add netherite ingot to {_alloweditems::*}
    if event-inventory's name is "&8Smithing table":
        if clicked slot is 30:
            wait 1 tick
            if {_alloweditems::*} does not contain event-slot:
                set {_m} to event-slot
                set event-slot to air
                add {_m} to player's inventory
            else:
                checkforupgrade(player)


function checkforupgrade(p: player):
    if slot 28 of {_p}'s current inventory is netherite upgrade smithing template:
        if slot 30 of {_p}'s current inventory is netherite ingot:
            if slot 29 of {_p}'s current inventory is diamond helmet:
                set {_i} to netherite helmet
            else if slot 29 of {_p}'s current inventory is diamond chestplate:
                set {_i} to netherite chestplate
            else if slot 29 of {_p}'s current inventory is diamond leggings:
                set {_i} to netherite leggings
            else if slot 29 of {_p}'s current inventory is diamond boots:
                set {_i} to netherite boots
            else if slot 29 of {_p}'s current inventory is diamond sword:
                set {_i} to netherite sword
            else if slot 29 of {_p}'s current inventory is diamond pickaxe:
                set {_i} to netherite pickaxe
            else if slot 29 of {_p}'s current inventory is diamond axe:
                set {_i} to netherite axe
            else if slot 29 of {_p}'s current inventory is diamond shovel:
                set {_i} to netherite shovel
            else if slot 29 of {_p}'s current inventory is diamond hoe:
                set {_i} to netherite hoe

            set {_l} to slot 29 of {_p}'s current inventory
            set enchantments of {_i} to enchantments of {_l}
            set durability of {_i} to durability of {_l} * 2
            set name of {_i} to name of {_l}
            set lore of {_i} to lore of {_l}

            

            set slot 34 of {_p}'s current inventory to {_i}
            
on inventory click:
    if event-inventory's name is "&8Smithing table":
        if clicked slot is 34:
            if event-slot is not air:
                set {_1} to slot 28 of player's current inventory
                set {_2} to slot 29 of player's current inventory
                set {_3} to slot 30 of player's current inventory
                remove 1 of {_1} from player's current inventory
                remove 1 of {_2} from player's current inventory
                remove 1 of {_3} from player's current inventory
                play sound "block.anvil.use" at player
            else:
                cancel event

on inventory close:
    if event-inventory's name is "&8Smithing table":
        if {client.%player%} is "eagler":
            set {_1} to slot 28 of player's current inventory
            set {_2} to slot 29 of player's current inventory
            set {_3} to slot 30 of player's current inventory
            set pickup delay of {_1} to 0 ticks
            set pickup delay of {_2} to 0 ticks
            set pickup delay of {_3} to 0 ticks
            drop {_1} at player
            drop {_2} at player
            drop {_3} at player