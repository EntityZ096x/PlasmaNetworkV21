on right click:
    if clicked block is smithing table:
        if {client.%player%} is not "eagler":
            stop    
        
        close player's inventory
        wait 1 tick
        
        set {_inv} to chest inventory with 5 rows named "&8Smithing table"
        
        set {_id} to 0
        loop 45 times:
            set slot {_id} of {_inv} to white stained glass pane named ""
            add 1 to {_id}

        set slot 11 of {_inv} to iron axe named "&r&fUpgrade Gear"
        set slot 28 of {_inv} to air
        set slot 29 of {_inv} to air
        set slot 30 of {_inv} to air
        set slot 32 of {_inv} to arrow named ""
        set slot 34 of {_inv} to air
        
        open {_inv} to player
    
on inventory click:
    if event-inventory's name is "&8Smithing table":
        if clicked slot is not 28, 29, 30 or 34:
            if event-item is arrow named "":
                cancel event
            if event-item is white stained glass pane named "":
                cancel event
            if event-item is iron axe named "&r&fUpgrade Gear":
                cancel event

on inventory click:
    add air to {_alloweditems::*}
    add netherite upgrade smithing template to {_alloweditems::*}
    if event-inventory's name is "&8Smithing table":
        if clicked slot is 28:
            wait 1 tick
            if {_alloweditems::*} does not contain event-slot:
                set {_m} to event-slot
                set event-slot to air
                add {_m} to player's inventory
            else:
                checkforupgrade(player)

