on join:
    set the join message to ""
    while {client.%player%} is not set:
        wait 1 tick
    if {client.%player%} is "eagler":
        broadcast formatted "&r[&a+&r] <hover:show_text:'&7This is a Eaglercraft player'>&r&e%player%"
    else:
        broadcast "&r[&a+&r] &r%player%"

on quit:
	set the quit message to "&r[&c-&r] &e%player%"